# ==============================================================
# DevOps/AI News + Jobs App — Environment Variables Template
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in real values in .env
#
# SECURITY RULES — READ BEFORE EDITING:
#   ✗ NEVER commit .env to git (it is gitignored)
#   ✗ NEVER put real API keys in this file (.env.example)
#   ✗ NEVER put secrets in config.yaml or any Python file
#   ✓ For local runs: use .env (gitignored)
#   ✓ For GitHub Actions: use Settings → Secrets → Actions
# ==============================================================

# --- OpenRouter (LLM relevance scoring + summarization) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini          # cheap fast model

# --- Git publish (Option B: self-hosted container pushes JSON) ---
# Leave empty when using GitHub Actions (Option A) — Actions uses GITHUB_TOKEN automatically.
GH_PAT=                                       # GitHub Personal Access Token with repo scope
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git
GIT_BRANCH=main
GIT_USER_NAME=devops-news-bot
GIT_USER_EMAIL=bot@example.com

# --- Worker behaviour ---
LOG_LEVEL=INFO
DRY_RUN=false                                 # true = collect/score but skip git push
