# ==============================================================
# DevOps/AI News + Jobs App — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.
# ==============================================================

# --- OpenRouter (LLM relevance scoring + summarization) ---
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini          # cheap fast model

# --- Git publish (Option B: self-hosted container pushes JSON) ---
# Leave empty when using GitHub Actions (Option A) — Actions uses GITHUB_TOKEN automatically.
GH_PAT=                                       # GitHub Personal Access Token with repo scope
GIT_REPO_URL=https://github.com/YOUR_ORG/YOUR_REPO.git
GIT_BRANCH=main
GIT_USER_NAME=devops-news-bot
GIT_USER_EMAIL=bot@example.com

# --- Worker behaviour ---
LOG_LEVEL=INFO
DRY_RUN=false                                 # true = collect/score but skip git push
